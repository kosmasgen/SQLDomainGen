<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/countryI18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-country-i18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="country_i18n" schemaName="pep_schema">
            <column name="country_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="country_i18n_pkey" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="country_i18n_pkey" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(400)">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_country_i18n_id" type="INTEGER">
            </column>
        </createTable>



        <addUniqueConstraint tableName="country_i18n" schemaName="pep_schema" columnNames="country_id, chamber_country_i18n_id" constraintName="country_i18n_"/>


        <addForeignKeyConstraint
                                 baseTableName="country_i18n"
                                 baseColumnNames="country_id"
                                 constraintName="fk_country_i18n"
                                 referencedTableName="country"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="country_i18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_country_i18n_lang"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="country_i18n_aud" schemaName="audit">
            <column name="country_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="description" type="VARCHAR(400)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="chamber_country_i18n_id" type="INTEGER"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="country_i18n_aud"
                       columnNames="country_id, language_id, rev"
                       constraintName="pk_country_i18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="country_i18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_country_i18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
