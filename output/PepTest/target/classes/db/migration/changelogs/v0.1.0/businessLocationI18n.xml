<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/businessLocationI18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-business-location-i18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="business_location_i18n" schemaName="pep_schema">
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="business_location_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="business_location_i18n_pkey" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="business_location_i18n_pkey" nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="business_location_i18n"
                                 baseColumnNames="business_location_id"
                                 constraintName="fk_business_location"
                                 referencedTableName="business_location"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"
                                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                                 baseTableName="business_location_i18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_business_location_language"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="business_location_i18n_aud" schemaName="audit">
            <column name="description" type="VARCHAR(255)"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="business_location_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="business_location_i18n_aud"
                       columnNames="business_location_id, language_id, rev"
                       constraintName="pk_business_location_i18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="business_location_i18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_business_location_i18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
