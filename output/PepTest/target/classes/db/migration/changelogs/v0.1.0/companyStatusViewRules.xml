<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyStatusViewRules.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-status-view-rules-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_status_view_rules" schemaName="pep_schema">
            <column name="company_status_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_status_view_rules" nullable="false"/>
            </column>
            <column name="company_view_rules_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_status_view_rules" nullable="false"/>
            </column>
            <column name="exclude_companies" type="BOOLEAN">
            </column>
            <column name="date_created" type="TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
        </createTable>




        <createIndex tableName="company_status_view_rules" schemaName="pep_schema" indexName="idx_company_status_view_rules_company_status_id">
            <column name="company_status_id"/>
        </createIndex>
        <createIndex tableName="company_status_view_rules" schemaName="pep_schema" indexName="idx_company_status_view_rules_company_view_rules_id">
            <column name="company_view_rules_id"/>
        </createIndex>
        <createIndex tableName="company_status_view_rules" schemaName="pep_schema" indexName="idx_company_status_view_rules_exclude_companies">
            <column name="exclude_companies"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="company_status_view_rules"
                                 baseColumnNames="company_status_id"
                                 constraintName="fk_company_status_rules_company_status"
                                 referencedTableName="company_status"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_status_view_rules"
                                 baseColumnNames="company_view_rules_id"
                                 constraintName="fk_company_status_rules_company_view"
                                 referencedTableName="company_view_rules"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_status_view_rules_aud" schemaName="audit">
            <column name="company_status_id" type="UUID"/>
            <column name="company_view_rules_id" type="UUID"/>
            <column name="exclude_companies" type="BOOLEAN"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_status_view_rules_aud"
                       columnNames="company_status_id, company_view_rules_id, rev"
                       constraintName="pk_company_status_view_rules_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_status_view_rules_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_status_view_rules_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
