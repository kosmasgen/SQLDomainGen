<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyContactMessage.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-contact-message-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_contact_message" schemaName="pep_schema">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_contact_message_pkey" nullable="false"/>
            </column>
            <column name="full_name" type="VARCHAR(100)">
            </column>
            <column name="sender_email" type="VARCHAR(255)">
            </column>
            <column name="subject" type="VARCHAR(150)">
            </column>
            <column name="message" type="VARCHAR(5000)">
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
            </column>
        </createTable>






        <createTable tableName="company_contact_message_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="full_name" type="VARCHAR(100)"/>
            <column name="sender_email" type="VARCHAR(255)"/>
            <column name="subject" type="VARCHAR(150)"/>
            <column name="message" type="VARCHAR(5000)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="company_id" type="UUID"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_contact_message_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_contact_message_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_contact_message_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_contact_message_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
