<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/company.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company" schemaName="pep_schema">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_pkey" nullable="false"/>
            </column>
            <column name="afm" type="VARCHAR(9)">
            </column>
            <column name="am" type="NUMERIC">
            </column>
            <column name="gemi_id" type="NUMERIC">
            </column>
            <column name="co_name" type="VARCHAR(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_company_id" type="NUMERIC">
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="cancel_date" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="date_interruption" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="member" type="NUMERIC">
            </column>
            <column name="rec_type" type="VARCHAR(1)">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
            </column>
            <column name="address_city" type="VARCHAR(50)">
            </column>
            <column name="address_latitude" type="VARCHAR(255)">
            </column>
            <column name="address_longitude" type="VARCHAR(255)">
            </column>
            <column name="address_municipality_pri_id" type="UUID">
            </column>
            <column name="address_region" type="VARCHAR(50)">
            </column>
            <column name="address_street" type="VARCHAR(255)">
            </column>
            <column name="address_street_number" type="VARCHAR(255)">
            </column>
            <column name="address_zip_code" type="VARCHAR(12)">
            </column>
            <column name="branch_type_id" type="NUMERIC">
            </column>
            <column name="chamber_department_id" type="UUID">
            </column>
            <column name="chamber_gemi_responsible_id" type="NUMERIC">
            </column>
            <column name="co_name_nrm" type="VARCHAR(1000)">
            </column>
            <column name="company_status_id" type="UUID">
            </column>
            <column name="contact_email" type="VARCHAR(100)">
            </column>
            <column name="contact_mobile" type="VARCHAR(50)">
            </column>
            <column name="contact_phone1" type="VARCHAR(20)">
            </column>
            <column name="contact_phone2" type="VARCHAR(20)">
            </column>
            <column name="contact_url" type="VARCHAR(100)">
            </column>
            <column name="corporate_status_id" type="UUID">
            </column>
            <column name="date_created" type="TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
            <column name="date_incorporated" type="TIMESTAMP">
            </column>
            <column name="date_registered" type="TIMESTAMP">
            </column>
            <column name="gemi_number" type="VARCHAR(12)">
            </column>
            <column name="objective" type="TEXT">
            </column>
            <column name="receive_newsletter" type="BOOLEAN">
            </column>
            <column name="is_chamber_company" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="is_trades_company" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="show_business_guide" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="business_location_id" type="UUID">
            </column>
            <column name="has_active_profiles" type="BOOLEAN" defaultValueBoolean="false">
            </column>
            <column name="is_proteas_data" type="BOOLEAN" defaultValueBoolean="false">
            </column>
            <column name="responsible_name" type="VARCHAR(255)">
            </column>
            <column name="address_country_id" type="UUID">
            </column>
            <column name="address_zoom_level" type="NUMERIC">
            </column>
            <column name="contact_phone3" type="VARCHAR(20)">
            </column>
            <column name="date_profession_started" type="TIMESTAMP">
            </column>
            <column name="foundation_date" type="TIMESTAMP">
            </column>
            <column name="me_criteria1_id" type="NUMERIC">
            </column>
            <column name="me_criteria2_id" type="NUMERIC">
            </column>
            <column name="me_criteria3_id" type="NUMERIC">
            </column>
            <column name="member_dues" type="TIMESTAMP">
            </column>
            <column name="jb_uuid" type="UUID">
            </column>
            <column name="jb_description" type="TEXT">
            </column>
            <column name="jb_number_employees" type="BIGINT">
            </column>
            <column name="jb_motto" type="VARCHAR(255)">
            </column>
            <column name="jb_email" type="VARCHAR(255)">
            </column>
            <column name="jb_linked_in_url" type="VARCHAR(255)">
            </column>
            <column name="jb_facebook_url" type="VARCHAR(255)">
            </column>
            <column name="jb_registration_status" type="VARCHAR(255)">
            </column>
            <column name="jb_logo_id" type="VARCHAR(255)">
            </column>
            <column name="jb_cover_id" type="VARCHAR(255)">
            </column>
            <column name="jb_location_id" type="INTEGER">
            </column>
            <column name="jb_industry_id" type="INTEGER">
            </column>
            <column name="jb_isvalid" type="BOOLEAN" defaultValueBoolean="false">
            </column>
            <column name="jb_activation_status" type="VARCHAR">
            </column>
        </createTable>



        <addUniqueConstraint tableName="company" schemaName="pep_schema" columnNames="chamber_id, chamber_company_id" constraintName="uk_company"/>

        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_afm">
            <column name="afm"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_am">
            <column name="am"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_chamber_id">
            <column name="chamber_id"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_co_name">
            <column name="co_name"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_corp_status">
            <column name="corporate_status_id"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_dt_registered">
            <column name="date_registered"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_gemi_id">
            <column name="gemi_id"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_gemi_number">
            <column name="gemi_number"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_jb_email">
            <column name="jb_email"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_jb_industry">
            <column name="jb_industry_id"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_jb_location">
            <column name="jb_location_id"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_jb_uuid">
            <column name="jb_uuid"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_member">
            <column name="member"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_rec_type">
            <column name="rec_type"/>
        </createIndex>
        <createIndex tableName="company" schemaName="pep_schema" indexName="idx_company_status">
            <column name="company_status_id"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="company"
                                 baseColumnNames="address_municipality_pri_id"
                                 constraintName="fk_company_municipality"
                                 referencedTableName="municipality"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company"
                                 baseColumnNames="chamber_department_id"
                                 constraintName="fk_company_chamber_depart"
                                 referencedTableName="chamber_department"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company"
                                 baseColumnNames="company_status_id"
                                 constraintName="fk_company_company_status"
                                 referencedTableName="company_status"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company"
                                 baseColumnNames="corporate_status_id"
                                 constraintName="fk_company_corporate_stat"
                                 referencedTableName="corporate_status"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company"
                                 baseColumnNames="business_location_id"
                                 constraintName="fk_company_business_location"
                                 referencedTableName="business_location"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"
                                onDelete="RESTRICT"/>
        <addForeignKeyConstraint
                                 baseTableName="company"
                                 baseColumnNames="address_country_id"
                                 constraintName="fk_company_country"
                                 referencedTableName="country"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="afm" type="VARCHAR(9)"/>
            <column name="am" type="NUMERIC"/>
