<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/languages.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-languages-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="languages" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_languages" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="cd" type="VARCHAR(3)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="descr" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_language_id" type="INTEGER">
                <constraints unique="true"/>
            </column>
        </createTable>






        <createTable tableName="languages_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="cd" type="VARCHAR(3)"/>
            <column name="descr" type="VARCHAR(50)"/>
            <column name="chamber_language_id" type="INTEGER"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="languages_aud"
                       columnNames="id, rev"
                       constraintName="pk_languages_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="languages_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_languages_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
