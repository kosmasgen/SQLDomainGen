<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyBgCooperation.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-bg-cooperation-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_bg_cooperation" schemaName="pep_schema">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_bg_cooperation_pkey" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="coop_company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="cooperation_status" type="VARCHAR(50)">
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="company_bg_cooperation"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_bg_cooperation_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_bg_cooperation"
                                 baseColumnNames="coop_company_id"
                                 constraintName="fk_company_bg_cooperation_coop_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_bg_cooperation_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="company_id" type="UUID"/>
            <column name="coop_company_id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="cooperation_status" type="VARCHAR(50)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_bg_cooperation_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_bg_cooperation_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_bg_cooperation_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_bg_cooperation_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
