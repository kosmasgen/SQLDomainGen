<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/chAppUserContact.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-ch-app-user-contact-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="ch_app_user_contact" schemaName="pep_schema">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_ch_app_user_contact" nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="chamber_app_user_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="phone1" type="VARCHAR(20)">
            </column>
            <column name="phone2" type="VARCHAR(20)">
            </column>
            <column name="mobile1" type="VARCHAR(20)">
            </column>
            <column name="mobile2" type="VARCHAR(20)">
            </column>
            <column name="email1" type="VARCHAR(100)">
            </column>
            <column name="email2" type="VARCHAR(100)">
            </column>
            <column name="url" type="VARCHAR(255)">
            </column>
            <column name="zip_code" type="VARCHAR(12)">
            </column>
            <column name="latitude" type="VARCHAR(255)">
            </column>
            <column name="longitude" type="VARCHAR(255)">
            </column>
            <column name="street_number" type="VARCHAR(255)">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="listing_url" type="VARCHAR(255)">
            </column>
            <column name="email" type="VARCHAR(255)">
            </column>
            <column name="mobile" type="VARCHAR(50)">
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="ch_app_user_contact"
                                 baseColumnNames="chamber_app_user_id"
                                 constraintName="fk_ch_app_user_contact_chamber_app_user"
                                 referencedTableName="chamber_app_user"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="ch_app_user_contact_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="chamber_app_user_id" type="UUID"/>
            <column name="phone1" type="VARCHAR(20)"/>
            <column name="phone2" type="VARCHAR(20)"/>
            <column name="mobile1" type="VARCHAR(20)"/>
            <column name="mobile2" type="VARCHAR(20)"/>
            <column name="email1" type="VARCHAR(100)"/>
            <column name="email2" type="VARCHAR(100)"/>
            <column name="url" type="VARCHAR(255)"/>
            <column name="zip_code" type="VARCHAR(12)"/>
            <column name="latitude" type="VARCHAR(255)"/>
            <column name="longitude" type="VARCHAR(255)"/>
            <column name="street_number" type="VARCHAR(255)"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="listing_url" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="mobile" type="VARCHAR(50)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="ch_app_user_contact_aud"
                       columnNames="id, rev"
                       constraintName="pk_ch_app_user_contact_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="ch_app_user_contact_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_ch_app_user_contact_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
