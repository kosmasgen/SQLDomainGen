<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/professionFriendlyCategory.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-profession-friendly-category-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="profession_friendly_category" schemaName="pep_schema">
            <column name="id" type="VARCHAR(100)">
                <constraints primaryKey="true" primaryKeyName="profession_friendly_category_pkey" nullable="false"/>
            </column>
            <column name="descr" type="VARCHAR(1000)">
            </column>
        </createTable>






        <createTable tableName="profession_friendly_category_aud" schemaName="audit">
            <column name="id" type="VARCHAR(100)"/>
            <column name="descr" type="VARCHAR(1000)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="profession_friendly_category_aud"
                       columnNames="id, rev"
                       constraintName="pk_profession_friendly_category_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="profession_friendly_category_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_profession_friendly_category_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
