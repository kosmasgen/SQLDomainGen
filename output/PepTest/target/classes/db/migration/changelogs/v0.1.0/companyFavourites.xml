<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyFavourites.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-favourites-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_favourites" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="company_favourites_pkey" nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="favourite_company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT">
            </column>
            <column name="favourite_profile_id" type="UUID">
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="company_favourites"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_favourites_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_favourites"
                                 baseColumnNames="favourite_company_id"
                                 constraintName="fk_company_favourites_favourite"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_favourites"
                                 baseColumnNames="favourite_profile_id"
                                 constraintName="fk_company_favourites_profile"
                                 referencedTableName="company_profile"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_favourites_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="company_id" type="UUID"/>
            <column name="favourite_company_id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="notes" type="TEXT"/>
            <column name="favourite_profile_id" type="UUID"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_favourites_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_favourites_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_favourites_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_favourites_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
