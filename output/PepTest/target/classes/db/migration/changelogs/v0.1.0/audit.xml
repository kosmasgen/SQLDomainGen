<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create_audit_schema" author="kosmasgenaris@knowledge.gr">
        <sql>
            CREATE SCHEMA IF NOT EXISTS audit;
        </sql>
    </changeSet>

        <changeSet id="create_pep_schema_schema" author="kosmasgenaris@knowledge.gr">
            <sql>
                CREATE SCHEMA IF NOT EXISTS pep_schema;
            </sql>
        </changeSet>

    <changeSet id="create_revision_info_table" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="REVINFO" schemaName="audit">
            <column name="REV" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="REVTSTMP" type="BIGINT"/>
        </createTable>
    </changeSet>

    <changeSet id="create_revinfo_sequence" author="kosmasgenaris@knowledge.gr">
        <createSequence sequenceName="revinfo_seq"
                        schemaName="pep_schema"
                        startValue="1"
                        incrementBy="50"/>
    </changeSet>

</databaseChangeLog>
