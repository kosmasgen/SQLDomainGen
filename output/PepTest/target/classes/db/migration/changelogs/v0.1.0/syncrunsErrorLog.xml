<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/syncrunsErrorLog.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-syncruns-error-log-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="syncruns_error_log" schemaName="pep_schema">
            <column name="id" type="SERIAL4">
                <constraints primaryKey="true" primaryKeyName="syn_error_pkey" nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT">
            </column>
            <column name="table_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="table_chamber_id" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="email_send_date" type="TIMESTAMP">
            </column>
        </createTable>






        <createTable tableName="syncruns_error_log_aud" schemaName="audit">
            <column name="id" type="SERIAL4"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="error_message" type="TEXT"/>
            <column name="table_name" type="VARCHAR(100)"/>
            <column name="table_chamber_id" type="NUMERIC"/>
            <column name="email_send_date" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="syncruns_error_log_aud"
                       columnNames="id, rev"
                       constraintName="pk_syncruns_error_log_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="syncruns_error_log_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_syncruns_error_log_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
