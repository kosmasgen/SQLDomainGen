<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyArticleFile.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-article-file-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_article_file" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="company_article_file_pkey" nullable="false"/>
            </column>
            <column name="article_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="file_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="order_seq" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="company_article_file"
                                 baseColumnNames="article_id"
                                 constraintName="fk_article"
                                 referencedTableName="company_yp_article"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_article_file"
                                 baseColumnNames="file_id"
                                 constraintName="fk_file"
                                 referencedTableName="company_file"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_article_file_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="article_id" type="UUID"/>
            <column name="file_id" type="UUID"/>
            <column name="order_seq" type="INTEGER"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_article_file_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_article_file_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_article_file_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_article_file_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
