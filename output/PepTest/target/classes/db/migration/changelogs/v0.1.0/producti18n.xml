<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/producti18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-producti18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="producti18n" schemaName="pep_schema">
            <column name="version" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_i18n_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_producti18n" nullable="false"/>
            </column>
            <column name="product_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_producti18n" nullable="false"/>
            </column>
            <column name="short_description" type="VARCHAR(35)">
            </column>
            <column name="date_created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="producti18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_producti18n_language"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="producti18n"
                                 baseColumnNames="product_id"
                                 constraintName="fk_producti18n_product"
                                 referencedTableName="product"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="producti18n_aud" schemaName="audit">
            <column name="version" type="INTEGER"/>
            <column name="description" type="VARCHAR(500)"/>
            <column name="chamber_i18n_id" type="BIGINT"/>
            <column name="language_id" type="UUID"/>
            <column name="product_id" type="UUID"/>
            <column name="short_description" type="VARCHAR(35)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="producti18n_aud"
                       columnNames="language_id, product_id, rev"
                       constraintName="pk_producti18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="producti18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_producti18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
