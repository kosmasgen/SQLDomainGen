<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyProfileI18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-profile-i18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_profile_i18n" schemaName="pep_schema">
            <column name="company_profile_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_profile_i18n_pkey" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_profile_i18n_pkey" nullable="false"/>
            </column>
            <column name="rec_deleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(1000)">
            </column>
            <column name="address_city" type="VARCHAR(50)">
            </column>
            <column name="address_region" type="VARCHAR(50)">
            </column>
            <column name="address_street" type="VARCHAR(100)">
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
            </column>
            <column name="objective" type="TEXT">
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="company_profile_i18n"
                                 baseColumnNames="company_profile_id"
                                 constraintName="fk_company_profile_i18n_profile"
                                 referencedTableName="company_profile"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_profile_i18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_company_profile_i18n_language"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_profile_i18n_aud" schemaName="audit">
            <column name="company_profile_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="rec_deleted" type="BOOLEAN"/>
            <column name="name" type="VARCHAR(1000)"/>
            <column name="address_city" type="VARCHAR(50)"/>
            <column name="address_region" type="VARCHAR(50)"/>
            <column name="address_street" type="VARCHAR(100)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="objective" type="TEXT"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_profile_i18n_aud"
                       columnNames="company_profile_id, language_id, rev"
                       constraintName="pk_company_profile_i18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_profile_i18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_profile_i18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
