<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyTitle.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-title-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_title" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_company_title" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(1000)">
            </column>
            <column name="chamber_title_id" type="NUMERIC">
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>



        <addUniqueConstraint tableName="company_title" schemaName="pep_schema" columnNames="chamber_id, chamber_title_id" constraintName="uk_chamber_company_title"/>

        <createIndex tableName="company_title" schemaName="pep_schema" indexName="company_title_company_id_IDX">
            <column name="company_id"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="company_title"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_title"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_title_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="title" type="VARCHAR(1000)"/>
            <column name="chamber_title_id" type="NUMERIC"/>
            <column name="company_id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_title_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_title_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_title_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_title_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
