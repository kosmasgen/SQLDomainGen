<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyStatusi18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-statusi18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_statusi18n" schemaName="pep_schema">
            <column name="company_status_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_status_i18n" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_status_i18n" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_i18n_id" type="INTEGER">
            </column>
        </createTable>



        <addUniqueConstraint tableName="company_statusi18n" schemaName="pep_schema" columnNames="company_status_id, chamber_i18n_id" constraintName="uk_co_status_i18n_chamber"/>


        <addForeignKeyConstraint
                                 baseTableName="company_statusi18n"
                                 baseColumnNames="company_status_id"
                                 constraintName="fk_co_status_i18n"
                                 referencedTableName="company_status"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_statusi18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_co_status_i18n_lang"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_statusi18n_aud" schemaName="audit">
            <column name="company_status_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="description" type="VARCHAR(100)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="chamber_i18n_id" type="INTEGER"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_statusi18n_aud"
                       columnNames="company_status_id, language_id, rev"
                       constraintName="pk_company_statusi18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_statusi18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_statusi18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
