<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyYpPhoto.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-yp-photo-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_yp_photo" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_company_photo" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="file_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="mime_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR">
            </column>
            <column name="order_seq" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="blob_uri" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
        </createTable>



        <addUniqueConstraint tableName="company_yp_photo" schemaName="pep_schema" columnNames="company_id, file_name" constraintName="company_yp_photo_un"/>


        <addForeignKeyConstraint
                                 baseTableName="company_yp_photo"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_photo"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_yp_photo_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="company_id" type="UUID"/>
            <column name="file_name" type="VARCHAR(100)"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="file_size" type="INTEGER"/>
            <column name="title" type="VARCHAR"/>
            <column name="order_seq" type="INTEGER"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="blob_uri" type="VARCHAR(2000)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_yp_photo_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_yp_photo_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_yp_photo_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_yp_photo_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
