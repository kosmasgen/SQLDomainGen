<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyFile.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-file-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_file" schemaName="pep_schema">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_file_pkey" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
            </column>
            <column name="file_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="file_size" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="blob_uri" type="VARCHAR(2000)">
                <constraints nullable="false"/>
            </column>
            <column name="order_seq" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN">
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
            </column>
            <column name="is_logo" type="BOOLEAN">
            </column>
            <column name="is_background" type="BOOLEAN" defaultValueBoolean="false">
            </column>
            <column name="company_profile_id" type="UUID">
            </column>
            <column name="is_embedded" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="company_file"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_file_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_file"
                                 baseColumnNames="language_id"
                                 constraintName="fk_company_file_language"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_file"
                                 baseColumnNames="company_profile_id"
                                 constraintName="fk_company_profile"
                                 referencedTableName="company_profile"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_file_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="file_name" type="VARCHAR(100)"/>
            <column name="file_size" type="INTEGER"/>
            <column name="blob_uri" type="VARCHAR(2000)"/>
            <column name="order_seq" type="INTEGER"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="company_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="is_logo" type="BOOLEAN"/>
            <column name="is_background" type="BOOLEAN"/>
            <column name="company_profile_id" type="UUID"/>
            <column name="is_embedded" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_file_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_file_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_file_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_file_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
