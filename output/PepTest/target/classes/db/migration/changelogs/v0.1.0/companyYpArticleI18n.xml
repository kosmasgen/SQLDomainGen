<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyYpArticleI18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-yp-article-i18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_yp_article_i18n" schemaName="pep_schema">
            <column name="company_article_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_article_i18n" nullable="false"/>
            </column>
            <column name="title" type="TEXT">
            </column>
            <column name="html" type="TEXT">
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_article_i18n" nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="company_yp_article_i18n"
                                 baseColumnNames="company_article_id"
                                 constraintName="fk_company_article_i18n_company_article"
                                 referencedTableName="company_yp_article"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_yp_article_i18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_company_article_i18n_language"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_yp_article_i18n_aud" schemaName="audit">
            <column name="company_article_id" type="UUID"/>
            <column name="title" type="TEXT"/>
            <column name="html" type="TEXT"/>
            <column name="language_id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_yp_article_i18n_aud"
                       columnNames="company_article_id, language_id, rev"
                       constraintName="pk_company_yp_article_i18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_yp_article_i18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_yp_article_i18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
