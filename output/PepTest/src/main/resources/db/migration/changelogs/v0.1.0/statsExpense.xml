<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/statsExpense.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-stats-expense-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="stats_expense" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_stats_expense" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="account_sum_id" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="cd_use" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
            <column name="group_descr" type="VARCHAR(300)">
            </column>
            <column name="mm" type="VARCHAR(2)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="NUMERIC(19,2)">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
            <column name="recdeleted" type="NUMERIC">
            </column>
        </createTable>



        <addUniqueConstraint tableName="stats_expense" schemaName="pep_schema" columnNames="chamber_id, account_sum_id" constraintName="uk_stats_expense"/>

        <createIndex tableName="stats_expense" schemaName="pep_schema" indexName="idx_stats_expense">
            <column name="group_descr"/>
        </createIndex>
        <createIndex tableName="stats_expense" schemaName="pep_schema" indexName="idx_stats_expenseer">
            <column name="chamber_id"/>
        </createIndex>


        <createTable tableName="stats_expense_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="account_sum_id" type="NUMERIC"/>
            <column name="cd_use" type="VARCHAR(4)"/>
            <column name="group_descr" type="VARCHAR(300)"/>
            <column name="mm" type="VARCHAR(2)"/>
            <column name="amount" type="NUMERIC(19,2)"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="NUMERIC"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="stats_expense_aud"
                       columnNames="id, rev"
                       constraintName="pk_stats_expense_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="stats_expense_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_stats_expense_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
