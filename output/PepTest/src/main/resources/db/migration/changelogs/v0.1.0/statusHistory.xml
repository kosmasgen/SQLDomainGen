<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/statusHistory.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-status-history-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="status_history" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_status_history" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_status_history_id" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="company_status_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(256)">
            </column>
            <column name="reg_dt" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="start_dt" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="gemi_id" type="NUMERIC">
            </column>
            <column name="gemi_date_created" type="TIMESTAMP">
            </column>
            <column name="gemi_last_updated" type="TIMESTAMP">
            </column>
            <column name="action_no" type="VARCHAR(50)">
            </column>
        </createTable>



        <addUniqueConstraint tableName="status_history" schemaName="pep_schema" columnNames="chamber_id, chamber_status_history_id" constraintName="uk_chamber_status_history"/>

        <createIndex tableName="status_history" schemaName="pep_schema" indexName="sh_company_id_idx">
            <column name="company_id"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="status_history"
                                 baseColumnNames="company_id"
                                 constraintName="fk_status_history"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="status_history"
                                 baseColumnNames="company_status_id"
                                 constraintName="fk_history_status"
                                 referencedTableName="company_status"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="status_history_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="chamber_status_history_id" type="NUMERIC"/>
            <column name="company_id" type="UUID"/>
            <column name="company_status_id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="notes" type="VARCHAR(256)"/>
            <column name="reg_dt" type="TIMESTAMP"/>
            <column name="start_dt" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="gemi_id" type="NUMERIC"/>
            <column name="gemi_date_created" type="TIMESTAMP"/>
            <column name="gemi_last_updated" type="TIMESTAMP"/>
            <column name="action_no" type="VARCHAR(50)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="status_history_aud"
                       columnNames="id, rev"
                       constraintName="pk_status_history_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="status_history_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_status_history_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
