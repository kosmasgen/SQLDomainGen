<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/temporaryCompanyTitlei18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-temporary-company-titlei18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="temporary_company_titlei18n" schemaName="pep_schema">
            <column name="id" type="NUMERIC(19)">
                <constraints primaryKey="true" primaryKeyName="pk_temporary_company_titlei18n" nullable="false"/>
            </column>
            <column name="version" type="NUMERIC(19)">
                <constraints nullable="false"/>
            </column>
            <column name="company_title_id" type="NUMERIC(19)">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="NUMERIC(19)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(1000)">
            </column>
            <column name="gemi_id" type="NUMERIC(19)">
            </column>
            <column name="gemi_date_created" type="DATE">
            </column>
            <column name="gemi_last_updated" type="DATE">
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="temporary_company_titlei18n"
                                 baseColumnNames="company_title_id"
                                 constraintName="fk_temporary_company_titlei18n_title"
                                 referencedTableName="temporary_company_title"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="temporary_company_titlei18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_temporary_company_titlei18n_lang"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="temporary_company_titlei18n_aud" schemaName="audit">
            <column name="id" type="NUMERIC(19)"/>
            <column name="version" type="NUMERIC(19)"/>
            <column name="company_title_id" type="NUMERIC(19)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="language_id" type="UUID"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="NUMERIC(19)"/>
            <column name="title" type="VARCHAR(1000)"/>
            <column name="gemi_id" type="NUMERIC(19)"/>
            <column name="gemi_date_created" type="DATE"/>
            <column name="gemi_last_updated" type="DATE"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="temporary_company_titlei18n_aud"
                       columnNames="id, rev"
                       constraintName="pk_temporary_company_titlei18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="temporary_company_titlei18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_temporary_company_titlei18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
