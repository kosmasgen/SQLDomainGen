<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyi18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-companyi18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="companyi18n" schemaName="pep_schema">
            <column name="company_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_companyi18n" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_companyi18n" nullable="false"/>
            </column>
            <column name="chamber_i18n_id" type="INTEGER">
                <constraints primaryKey="true" primaryKeyName="pk_companyi18n" nullable="false"/>
            </column>
            <column name="city" type="VARCHAR(50)">
            </column>
            <column name="co_name" type="VARCHAR(1000)">
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="objective" type="TEXT">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="street" type="VARCHAR(60)">
            </column>
            <column name="responsible_name" type="VARCHAR(255)">
            </column>
        </createTable>



        <addUniqueConstraint tableName="companyi18n" schemaName="pep_schema" columnNames="company_id, chamber_i18n_id" constraintName="uk_company_chamber_i18n"/>


        <addForeignKeyConstraint
                                 baseTableName="companyi18n"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_i18n_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"
                                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                                 baseTableName="companyi18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_company_i18n_language"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="companyi18n_aud" schemaName="audit">
            <column name="company_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="chamber_i18n_id" type="INTEGER"/>
            <column name="city" type="VARCHAR(50)"/>
            <column name="co_name" type="VARCHAR(1000)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="objective" type="TEXT"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="street" type="VARCHAR(60)"/>
            <column name="responsible_name" type="VARCHAR(255)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="companyi18n_aud"
                       columnNames="company_id, language_id, chamber_i18n_id, rev"
                       constraintName="pk_companyi18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="companyi18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_companyi18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
