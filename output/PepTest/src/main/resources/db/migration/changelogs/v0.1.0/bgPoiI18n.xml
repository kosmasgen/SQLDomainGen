<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/bgPoiI18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-bg-poi-i18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="bg_poi_i18n" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_bg_poi_i18n" nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="poi_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="bg_poi_i18n"
                                 baseColumnNames="poi_id"
                                 constraintName="fk_poi_id"
                                 referencedTableName="bg_poi"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="bg_poi_i18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_language_id"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="bg_poi_i18n_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="title" type="VARCHAR(255)"/>
            <column name="poi_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="bg_poi_i18n_aud"
                       columnNames="id, rev"
                       constraintName="pk_bg_poi_i18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="bg_poi_i18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_bg_poi_i18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
