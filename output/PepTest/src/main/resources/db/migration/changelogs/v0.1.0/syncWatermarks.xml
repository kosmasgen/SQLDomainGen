<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/syncWatermarks.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-sync-watermarks-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="sync_watermarks" schemaName="pep_schema">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="sync_watermarks_pkey" nullable="false"/>
            </column>
            <column name="table_name" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="last_sync_timestamp" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>






        <createTable tableName="sync_watermarks_aud" schemaName="audit">
            <column name="id" type="BIGINT"/>
            <column name="table_name" type="VARCHAR(100)"/>
            <column name="last_sync_timestamp" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="sync_watermarks_aud"
                       columnNames="id, rev"
                       constraintName="pk_sync_watermarks_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="sync_watermarks_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_sync_watermarks_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
