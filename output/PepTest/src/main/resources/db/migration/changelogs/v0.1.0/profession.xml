<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/profession.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-profession-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="profession" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_profession" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_profession_id" type="INTEGER">
            </column>
            <column name="parent_profession_id" type="UUID">
            </column>
            <column name="profession_system_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="proteas_id" type="NUMERIC(19)">
            </column>
            <column name="friendly_cat_id" type="VARCHAR(100)">
            </column>
        </createTable>



        <addUniqueConstraint tableName="profession" schemaName="pep_schema" columnNames="chamber_id, chamber_profession_id" constraintName="uk_chamber_profession"/>

        <createIndex tableName="profession" schemaName="pep_schema" indexName="profession_code_IDX">
            <column name="code"/>
        </createIndex>
        <createIndex tableName="profession" schemaName="pep_schema" indexName="profession_date_created_IDX">
            <column name="date_created"/>
        </createIndex>
        <createIndex tableName="profession" schemaName="pep_schema" indexName="profession_last_updated_IDX">
            <column name="last_updated"/>
        </createIndex>
        <createIndex tableName="profession" schemaName="pep_schema" indexName="profession_parent_profession_id_IDX">
            <column name="parent_profession_id"/>
        </createIndex>
        <createIndex tableName="profession" schemaName="pep_schema" indexName="profession_profession_system_id_IDX">
            <column name="profession_system_id"/>
        </createIndex>
        <createIndex tableName="profession" schemaName="pep_schema" indexName="profession_recdeleted_IDX">
            <column name="recdeleted"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="profession"
                                 baseColumnNames="parent_profession_id"
                                 constraintName="fk_parent_profession"
                                 referencedTableName="profession"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="profession"
                                 baseColumnNames="profession_system_id"
                                 constraintName="fk_prof_system"
                                 referencedTableName="profession_system"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="profession"
                                 baseColumnNames="friendly_cat_id"
                                 constraintName="fk_profession_friendly_category"
                                 referencedTableName="profession_friendly_category"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="profession_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="chamber_profession_id" type="INTEGER"/>
            <column name="parent_profession_id" type="UUID"/>
            <column name="profession_system_id" type="UUID"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="proteas_id" type="NUMERIC(19)"/>
            <column name="friendly_cat_id" type="VARCHAR(100)"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="profession_aud"
                       columnNames="id, rev"
                       constraintName="pk_profession_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="profession_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_profession_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
