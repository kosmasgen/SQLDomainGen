<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyTitlei18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-titlei18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_titlei18n" schemaName="pep_schema">
            <column name="company_title_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_titlei18n" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_company_titlei18n" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(1000)">
            </column>
            <column name="date_created" type="TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
            <column name="chamber_i18n_id" type="INTEGER">
                <constraints primaryKey="true" primaryKeyName="pk_company_titlei18n" nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>



        <addUniqueConstraint tableName="company_titlei18n" schemaName="pep_schema" columnNames="company_title_id, chamber_i18n_id" constraintName="uk_chamber_co_title_i18n"/>

        <createIndex tableName="company_titlei18n" schemaName="pep_schema" indexName="company_titlei18n_company_title_id_IDX">
            <column name="company_title_id"/>
        </createIndex>
        <createIndex tableName="company_titlei18n" schemaName="pep_schema" indexName="company_titlei18n_title_idx">
            <column name="title"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="company_titlei18n"
                                 baseColumnNames="company_title_id"
                                 constraintName="fk_co_title_i18n"
                                 referencedTableName="company_title"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_titlei18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_co_title_i18n_lang"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_titlei18n_aud" schemaName="audit">
            <column name="company_title_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="title" type="VARCHAR(1000)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="chamber_i18n_id" type="INTEGER"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_titlei18n_aud"
                       columnNames="company_title_id, language_id, chamber_i18n_id, rev"
                       constraintName="pk_company_titlei18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_titlei18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_titlei18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
