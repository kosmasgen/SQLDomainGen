<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyViewRules.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-view-rules-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_view_rules" schemaName="pep_schema">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="company_view_rules_pkey" nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_id" type="BIGINT">
            </column>
            <column name="show_mobile_phone" type="BOOLEAN">
            </column>
            <column name="show_phones" type="BOOLEAN">
            </column>
            <column name="show_email" type="BOOLEAN">
            </column>
            <column name="show_afm" type="BOOLEAN">
            </column>
            <column name="show_business_information" type="BOOLEAN">
            </column>
        </createTable>






        <createTable tableName="company_view_rules_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="chamber_id" type="BIGINT"/>
            <column name="show_mobile_phone" type="BOOLEAN"/>
            <column name="show_phones" type="BOOLEAN"/>
            <column name="show_email" type="BOOLEAN"/>
            <column name="show_afm" type="BOOLEAN"/>
            <column name="show_business_information" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_view_rules_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_view_rules_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_view_rules_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_view_rules_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
