<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/municipality.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-municipality-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="municipality" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="municipality_pkey" nullable="false"/>
            </column>
            <column name="chamber_id" type="BIGINT">
            </column>
            <column name="chamber_municipality_id" type="BIGINT">
            </column>
            <column name="description" type="VARCHAR(255)">
            </column>
            <column name="date_created" type="TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
            </column>
            <column name="cd" type="VARCHAR(255)" defaultValue="">
                <constraints nullable="false"/>
            </column>
            <column name="is_proteas_data" type="BOOLEAN" defaultValueBoolean="false">
            </column>
        </createTable>



        <addUniqueConstraint tableName="municipality" schemaName="pep_schema" columnNames="chamber_id, chamber_municipality_id" constraintName="municipality_chamber_"/>



        <createTable tableName="municipality_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="BIGINT"/>
            <column name="chamber_municipality_id" type="BIGINT"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="cd" type="VARCHAR(255)"/>
            <column name="is_proteas_data" type="BOOLEAN"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="municipality_aud"
                       columnNames="id, rev"
                       constraintName="pk_municipality_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="municipality_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_municipality_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
