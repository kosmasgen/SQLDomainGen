<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/userContactinfo.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-user-contactinfo-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="user_contactinfo" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="user_contactinfo_pkey" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
            </column>
            <column name="phone" type="VARCHAR(20)">
            </column>
            <column name="mobile" type="VARCHAR(50)">
            </column>
            <column name="contact_url" type="VARCHAR(255)">
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="user_contactinfo"
                                 baseColumnNames="company_id"
                                 constraintName="fk_user_contactinfo_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="user_contactinfo_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="company_id" type="UUID"/>
            <column name="username" type="TEXT"/>
            <column name="email" type="VARCHAR(100)"/>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="mobile" type="VARCHAR(50)"/>
            <column name="contact_url" type="VARCHAR(255)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="user_contactinfo_aud"
                       columnNames="id, rev"
                       constraintName="pk_user_contactinfo_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="user_contactinfo_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_user_contactinfo_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
