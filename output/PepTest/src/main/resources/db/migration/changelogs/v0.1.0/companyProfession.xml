<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/companyProfession.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-company-profession-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="company_profession" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="company_profession_pkey" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_company_profession_id" type="INTEGER">
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="profession_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="profession_kind_id" type="UUID">
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="from_date" type="TIMESTAMP">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="to_date" type="TIMESTAMP">
            </column>
            <column name="profile_id" type="UUID">
            </column>
            <column name="gemi_id" type="NUMERIC">
            </column>
            <column name="gemi_date_created" type="TIMESTAMP">
            </column>
            <column name="gemi_last_updated" type="TIMESTAMP">
            </column>
        </createTable>



        <addUniqueConstraint tableName="company_profession" schemaName="pep_schema" columnNames="chamber_id, chamber_company_profession_id" constraintName="uk_chamber_company_profession"/>

        <createIndex tableName="company_profession" schemaName="pep_schema" indexName="idx_company_profession_chamber_company">
            <column name="chamber_id"/>
            <column name="company_id"/>
        </createIndex>
        <createIndex tableName="company_profession" schemaName="pep_schema" indexName="idx_company_profession_kind_idx">
            <column name="profession_kind_id"/>
        </createIndex>
        <createIndex tableName="company_profession" schemaName="pep_schema" indexName="idx_cp_chamber_profession_idx">
            <column name="chamber_id"/>
            <column name="profession_kind_id"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="company_profession"
                                 baseColumnNames="company_id"
                                 constraintName="fk_company_id"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_profession"
                                 baseColumnNames="profession_id"
                                 constraintName="fk_profession_id"
                                 referencedTableName="profession"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_profession"
                                 baseColumnNames="profession_kind_id"
                                 constraintName="fk_profession_kind_id"
                                 referencedTableName="profession_kind"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="company_profession"
                                 baseColumnNames="profile_id"
                                 constraintName="fk_company_profession_profile"
                                 referencedTableName="company_profile"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="company_profession_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="chamber_company_profession_id" type="INTEGER"/>
            <column name="company_id" type="UUID"/>
            <column name="profession_id" type="UUID"/>
            <column name="profession_kind_id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="from_date" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="to_date" type="TIMESTAMP"/>
            <column name="profile_id" type="UUID"/>
            <column name="gemi_id" type="NUMERIC"/>
            <column name="gemi_date_created" type="TIMESTAMP"/>
            <column name="gemi_last_updated" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="company_profession_aud"
                       columnNames="id, rev"
                       constraintName="pk_company_profession_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="company_profession_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_company_profession_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
