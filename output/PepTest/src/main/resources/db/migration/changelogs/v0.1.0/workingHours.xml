<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/workingHours.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-working-hours-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="working_hours" schemaName="pep_schema">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="working_hours_pkey" nullable="false"/>
            </column>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="day_of_week" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="opening_time" type="TIME">
            </column>
            <column name="closing_time" type="TIME">
            </column>
            <column name="is_closed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="profile_id" type="UUID">
            </column>
        </createTable>





        <addForeignKeyConstraint
                                 baseTableName="working_hours"
                                 baseColumnNames="company_id"
                                 constraintName="fk_working_hours_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="working_hours"
                                 baseColumnNames="profile_id"
                                 constraintName="fk_working_hours_profile"
                                 referencedTableName="company_profile"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="working_hours_aud" schemaName="audit">
            <column name="id" type="BIGINT"/>
            <column name="company_id" type="UUID"/>
            <column name="day_of_week" type="VARCHAR(20)"/>
            <column name="opening_time" type="TIME"/>
            <column name="closing_time" type="TIME"/>
            <column name="is_closed" type="BOOLEAN"/>
            <column name="profile_id" type="UUID"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="working_hours_aud"
                       columnNames="id, rev"
                       constraintName="pk_working_hours_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="working_hours_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_working_hours_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
