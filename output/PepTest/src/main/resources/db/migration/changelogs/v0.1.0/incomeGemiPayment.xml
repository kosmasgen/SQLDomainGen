<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/incomeGemiPayment.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-income-gemi-payment-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="income_gemi_payment" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_income_gemi_payment" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="payment_type" type="VARCHAR(255)">
            </column>
            <column name="sale_ts" type="TIMESTAMP">
            </column>
            <column name="chamber_amount" type="NUMERIC(19,2)">
            </column>
            <column name="chamber_amount_for_certs" type="NUMERIC(19,2)">
            </column>
            <column name="chamber_amount_for_postal" type="NUMERIC(19,2)">
            </column>
            <column name="total_amount_paid" type="NUMERIC(19,2)">
            </column>
            <column name="descr" type="VARCHAR(500)">
            </column>
            <column name="payer" type="VARCHAR(500)">
            </column>
            <column name="gemi_payment_id" type="NUMERIC">
                <constraints nullable="false"/>
            </column>
            <column name="company_gemi_id" type="NUMERIC">
            </column>
            <column name="co_name" type="VARCHAR(1000)">
            </column>
            <column name="company_chamber_id" type="NUMERIC">
            </column>
            <column name="payment_method" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="ri3" type="VARCHAR(25)">
            </column>
            <column name="subscription_start_date" type="TIMESTAMP">
            </column>
            <column name="subscription_end_date" type="TIMESTAMP">
            </column>
            <column name="cancel_flag" type="NUMERIC">
            </column>
            <column name="refund_ts" type="TIMESTAMP">
            </column>
            <column name="remittance_dt" type="TIMESTAMP">
            </column>
            <column name="remittance_amount" type="NUMERIC(19,2)">
            </column>
            <column name="remittance_reference" type="VARCHAR(20)">
            </column>
            <column name="last_updated" type="TIMESTAMP">
            </column>
        </createTable>



        <addUniqueConstraint tableName="income_gemi_payment" schemaName="pep_schema" columnNames="chamber_id, gemi_payment_id, payment_type, cancel_flag" constraintName="uk_income_gemi_payment"/>

        <createIndex tableName="income_gemi_payment" schemaName="pep_schema" indexName="idx_gemi_pay_chamber">
            <column name="chamber_id"/>
        </createIndex>
        <createIndex tableName="income_gemi_payment" schemaName="pep_schema" indexName="idx_gemi_pay_comp">
            <column name="company_gemi_id"/>
        </createIndex>
        <createIndex tableName="income_gemi_payment" schemaName="pep_schema" indexName="idx_gemi_pay_dt">
            <column name="sale_ts"/>
        </createIndex>


        <createTable tableName="income_gemi_payment_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="payment_type" type="VARCHAR(255)"/>
            <column name="sale_ts" type="TIMESTAMP"/>
            <column name="chamber_amount" type="NUMERIC(19,2)"/>
            <column name="chamber_amount_for_certs" type="NUMERIC(19,2)"/>
            <column name="chamber_amount_for_postal" type="NUMERIC(19,2)"/>
            <column name="total_amount_paid" type="NUMERIC(19,2)"/>
            <column name="descr" type="VARCHAR(500)"/>
            <column name="payer" type="VARCHAR(500)"/>
            <column name="gemi_payment_id" type="NUMERIC"/>
            <column name="company_gemi_id" type="NUMERIC"/>
            <column name="co_name" type="VARCHAR(1000)"/>
            <column name="company_chamber_id" type="NUMERIC"/>
            <column name="payment_method" type="VARCHAR(255)"/>
            <column name="ri3" type="VARCHAR(25)"/>
            <column name="subscription_start_date" type="TIMESTAMP"/>
            <column name="subscription_end_date" type="TIMESTAMP"/>
            <column name="cancel_flag" type="NUMERIC"/>
            <column name="refund_ts" type="TIMESTAMP"/>
            <column name="remittance_dt" type="TIMESTAMP"/>
            <column name="remittance_amount" type="NUMERIC(19,2)"/>
            <column name="remittance_reference" type="VARCHAR(20)"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="income_gemi_payment_aud"
                       columnNames="id, rev"
                       constraintName="pk_income_gemi_payment_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="income_gemi_payment_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_income_gemi_payment_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
