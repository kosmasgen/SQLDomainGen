<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/professionKindi18n.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-profession-kindi18n-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="profession_kindi18n" schemaName="pep_schema">
            <column name="profession_kind_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_prof_kind_i18n" nullable="false"/>
            </column>
            <column name="language_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_prof_kind_i18n" nullable="false"/>
            </column>
            <column name="recdeleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="last_updated" type="TIMESTAMP" defaultValueComputed="now()">
            </column>
            <column name="chamber_i18n_id" type="INTEGER">
            </column>
        </createTable>



        <addUniqueConstraint tableName="profession_kindi18n" schemaName="pep_schema" columnNames="profession_kind_id, chamber_i18n_id" constraintName="uk_chamber_prof_kind_i18n"/>


        <addForeignKeyConstraint
                                 baseTableName="profession_kindi18n"
                                 baseColumnNames="profession_kind_id"
                                 constraintName="fk_prof_kind_i18n"
                                 referencedTableName="profession_kind"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="profession_kindi18n"
                                 baseColumnNames="language_id"
                                 constraintName="fk_prof_kind_i18n_lang"
                                 referencedTableName="languages"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="profession_kindi18n_aud" schemaName="audit">
            <column name="profession_kind_id" type="UUID"/>
            <column name="language_id" type="UUID"/>
            <column name="recdeleted" type="BOOLEAN"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="chamber_i18n_id" type="INTEGER"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="profession_kindi18n_aud"
                       columnNames="profession_kind_id, language_id, rev"
                       constraintName="pk_profession_kindi18n_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="profession_kindi18n_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_profession_kindi18n_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
