<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/auditTrail.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-audit-trail-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="audit_trail" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_audit_trail" nullable="false"/>
            </column>
            <column name="date_created" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="ip" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="complete_uri" type="TEXT">
            </column>
            <column name="company_id" type="UUID">
            </column>
            <column name="profile_id" type="UUID">
            </column>
            <column name="country_id" type="UUID">
            </column>
        </createTable>

        <sql><![CDATA[
            ALTER TABLE pep_schema.audit_trail
            ADD COLUMN uri_path TEXT GENERATED ALWAYS AS (regexp_replace(complete_uri,'^GET https?://[^/]+'::text,''::text)) STORED;
        ]]></sql>



        <createIndex tableName="audit_trail" schemaName="pep_schema" indexName="idx_audit_trail_uri_path">
            <column name="uri_path"/>
        </createIndex>

        <addForeignKeyConstraint
                                 baseTableName="audit_trail"
                                 baseColumnNames="company_id"
                                 constraintName="fk_audit_trail_company"
                                 referencedTableName="company"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="audit_trail"
                                 baseColumnNames="profile_id"
                                 constraintName="fk_audit_trail_profile"
                                 referencedTableName="company_profile"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>
        <addForeignKeyConstraint
                                 baseTableName="audit_trail"
                                 baseColumnNames="country_id"
                                 constraintName="fk_audit_trail_country"
                                 referencedTableName="country"
                                 referencedColumnNames="id"
                                baseTableSchemaName="pep_schema"
                                referencedTableSchemaName="pep_schema"/>

        <createTable tableName="audit_trail_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="date_created" type="TIMESTAMP"/>
            <column name="ip" type="VARCHAR(50)"/>
            <column name="complete_uri" type="TEXT"/>
            <column name="company_id" type="UUID"/>
            <column name="profile_id" type="UUID"/>
            <column name="uri_path" type="TEXT"/>
            <column name="country_id" type="UUID"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="audit_trail_aud"
                       columnNames="id, rev"
                       constraintName="pk_audit_trail_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="audit_trail_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_audit_trail_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
