<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
        logicalFilePath="v0.1.0/incomePaymentMethod.xml"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.11.xsd">

    <changeSet id="create-income-payment-method-table-and-audit" author="kosmasgenaris@knowledge.gr">
        <createTable tableName="income_payment_method" schemaName="pep_schema">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_income_payment_method" nullable="false"/>
            </column>
            <column name="chamber_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="chamber_pay_method_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="recdeleted" type="INTEGER">
            </column>
        </createTable>



        <addUniqueConstraint tableName="income_payment_method" schemaName="pep_schema" columnNames="chamber_id, chamber_pay_method_id" constraintName="uk_in_pay_method"/>



        <createTable tableName="income_payment_method_aud" schemaName="audit">
            <column name="id" type="UUID"/>
            <column name="chamber_id" type="INTEGER"/>
            <column name="chamber_pay_method_id" type="INTEGER"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="last_updated" type="TIMESTAMP"/>
            <column name="recdeleted" type="INTEGER"/>
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
        </createTable>

        <addPrimaryKey tableName="income_payment_method_aud"
                       columnNames="id, rev"
                       constraintName="pk_income_payment_method_aud"
                       schemaName="audit"/>

        <addForeignKeyConstraint baseTableName="income_payment_method_aud"
                                 baseColumnNames="rev"
                                 constraintName="fk_income_payment_method_aud_revinfo"
                                 referencedTableName="REVINFO"
                                 referencedColumnNames="REV"
                                 baseTableSchemaName="audit"
                                 referencedTableSchemaName="audit"/>

    </changeSet>

</databaseChangeLog>
